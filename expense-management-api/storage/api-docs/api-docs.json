{
  "openapi": "3.0.0",
  "info": {
    "title": "SpendWise API",
    "version": "1.0.0",
    "description": "API for managing expenses, budgets, balances and group contexts"
  },
  "servers": [
    {
      "url": "http://localhost:8000/api",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password", "password_confirmation"],
                "properties": {
                  "name": { "type": "string", "example": "John Doe" },
                  "email": { "type": "string", "format": "email", "example": "john@example.com" },
                  "password": { "type": "string", "format": "password", "example": "password123" },
                  "password_confirmation": { "type": "string", "format": "password", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registration successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "user": { "$ref": "#/components/schemas/User" },
                    "token": { "type": "string" },
                    "token_type": { "type": "string", "example": "bearer" },
                    "expires_in": { "type": "integer" }
                  }
                }
              }
            }
          },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Login and get JWT token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "john@example.com" },
                  "password": { "type": "string", "format": "password", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": { "$ref": "#/components/schemas/User" },
                    "token": { "type": "string" },
                    "token_type": { "type": "string", "example": "bearer" },
                    "expires_in": { "type": "integer" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Logout (invalidate token)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Logged out successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Logged out successfully." }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Get authenticated user",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Current user data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Refresh JWT token",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Token refreshed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": { "$ref": "#/components/schemas/User" },
                    "token": { "type": "string" },
                    "token_type": { "type": "string", "example": "bearer" },
                    "expires_in": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/forgot-password": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Send password reset link",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "john@example.com" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Reset link sent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Password reset link sent to your email." }
                  }
                }
              }
            }
          },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/auth/reset-password": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Reset password with token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "token", "password", "password_confirmation"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "token": { "type": "string" },
                  "password": { "type": "string", "format": "password" },
                  "password_confirmation": { "type": "string", "format": "password" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Password reset successfully. Please log in." }
                  }
                }
              }
            }
          },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/auth/google/redirect": {
      "get": {
        "tags": ["OAuth"],
        "summary": "Get Google OAuth redirect URL",
        "responses": {
          "200": {
            "description": "Google OAuth redirect URL",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "redirect_url": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/google/callback": {
      "get": {
        "tags": ["OAuth"],
        "summary": "Handle Google OAuth callback",
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": { "$ref": "#/components/schemas/User" },
                    "token": { "type": "string" },
                    "token_type": { "type": "string", "example": "bearer" },
                    "expires_in": { "type": "integer" }
                  }
                }
              }
            }
          },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/auth/profile": {
      "patch": {
        "tags": ["Profile"],
        "summary": "Update user profile",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "example": "John Updated" },
                  "avatar_url": { "type": "string", "format": "uri" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "user": { "$ref": "#/components/schemas/User" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/categories": {
      "get": {
        "tags": ["Categories"],
        "summary": "List categories for a context",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "context_id", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "List of categories",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Category" }
                }
              }
            }
          },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      },
      "post": {
        "tags": ["Categories"],
        "summary": "Create a custom category (Pro only)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["context_id", "name", "icon"],
                "properties": {
                  "context_id": { "type": "string", "format": "uuid" },
                  "name": { "type": "string", "example": "Groceries" },
                  "icon": { "type": "string", "example": "shopping-cart" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Category created" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/categories/{category}": {
      "delete": {
        "tags": ["Categories"],
        "summary": "Delete a custom category",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "category", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Category deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Category deleted." }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/expenses": {
      "get": {
        "tags": ["Expenses"],
        "summary": "List expenses (paginated, filterable)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "context_id", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "date_from", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "date_to", "in": "query", "schema": { "type": "string", "format": "date" } },
          { "name": "category_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "keyword", "in": "query", "schema": { "type": "string" } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "Paginated expenses",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Expense" } },
                    "current_page": { "type": "integer" },
                    "last_page": { "type": "integer" },
                    "per_page": { "type": "integer" },
                    "total": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Expenses"],
        "summary": "Create a new expense",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["context_id", "amount", "expense_date", "split_type"],
                "properties": {
                  "context_id": { "type": "string", "format": "uuid" },
                  "description": { "type": "string", "maxLength": 255 },
                  "category_id": { "type": "string", "format": "uuid", "nullable": true },
                  "amount": { "type": "number", "minimum": 0.01, "example": 50.00 },
                  "expense_date": { "type": "string", "format": "date", "example": "2026-04-26" },
                  "note": { "type": "string", "maxLength": 500 },
                  "split_type": { "type": "string", "enum": ["none", "equal", "custom", "percentage"] },
                  "splits": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "user_id": { "type": "string", "format": "uuid" },
                        "share_amount": { "type": "number" },
                        "percentage": { "type": "number" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Expense created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Expense logged successfully." },
                    "expense": { "$ref": "#/components/schemas/Expense" }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/expenses/{expense}": {
      "get": {
        "tags": ["Expenses"],
        "summary": "Get a single expense",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "expense", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Expense details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Expense" }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "put": {
        "tags": ["Expenses"],
        "summary": "Update an expense",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "expense", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "description": { "type": "string" },
                  "category_id": { "type": "string", "format": "uuid", "nullable": true },
                  "amount": { "type": "number" },
                  "expense_date": { "type": "string", "format": "date" },
                  "note": { "type": "string" },
                  "split_type": { "type": "string", "enum": ["none", "equal", "custom", "percentage"] },
                  "splits": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "user_id": { "type": "string", "format": "uuid" },
                        "share_amount": { "type": "number" },
                        "percentage": { "type": "number" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Expense updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "expense": { "$ref": "#/components/schemas/Expense" }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "delete": {
        "tags": ["Expenses"],
        "summary": "Delete an expense (reverses balance changes)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "expense", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Expense deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Expense deleted successfully." }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/expenses/{expense}/settle": {
      "patch": {
        "tags": ["Expenses"],
        "summary": "Mark expense as settled",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "expense", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Expense marked as settled",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "expense": { "$ref": "#/components/schemas/Expense" }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/balances/summary": {
      "get": {
        "tags": ["Balances"],
        "summary": "Get balance summary for a context",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "context_id", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Balance summary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "balances": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "from_user": { "$ref": "#/components/schemas/User" },
                          "to_user": { "$ref": "#/components/schemas/User" },
                          "amount": { "type": "number" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/balances/settlements": {
      "get": {
        "tags": ["Balances"],
        "summary": "Get settlement history",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "context_id", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "Settlement history",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Settlement" }
                    }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "post": {
        "tags": ["Balances"],
        "summary": "Record a settlement",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["context_id", "payer_id", "receiver_id", "amount"],
                "properties": {
                  "context_id": { "type": "string", "format": "uuid" },
                  "payer_id": { "type": "string", "format": "uuid" },
                  "receiver_id": { "type": "string", "format": "uuid" },
                  "amount": { "type": "number", "minimum": 0.01 },
                  "method": { "type": "string", "example": "cash", "maxLength": 50 },
                  "note": { "type": "string", "maxLength": 300 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Settlement recorded",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "settlement": { "$ref": "#/components/schemas/Settlement" }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/budgets": {
      "get": {
        "tags": ["Budgets"],
        "summary": "List budgets with progress for a month",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "context_id", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "month", "in": "query", "required": true, "schema": { "type": "integer", "minimum": 1, "maximum": 12 } },
          { "name": "year", "in": "query", "required": true, "schema": { "type": "integer", "minimum": 2000, "maximum": 2100 } }
        ],
        "responses": {
          "200": {
            "description": "Budgets with consumed percentages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "month": { "type": "integer" },
                    "year": { "type": "integer" },
                    "budgets": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Budget" }
                    }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      },
      "post": {
        "tags": ["Budgets"],
        "summary": "Create a budget (overall or per-category)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["context_id", "month", "year", "amount"],
                "properties": {
                  "context_id": { "type": "string", "format": "uuid" },
                  "category_id": { "type": "string", "format": "uuid", "nullable": true, "description": "Null for overall budget" },
                  "month": { "type": "integer", "minimum": 1, "maximum": 12 },
                  "year": { "type": "integer", "minimum": 2000, "maximum": 2100 },
                  "amount": { "type": "number", "minimum": 0.01 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Budget created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "budget": { "$ref": "#/components/schemas/Budget" }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/budgets/{budget}": {
      "put": {
        "tags": ["Budgets"],
        "summary": "Update budget amount",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "budget", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["amount"],
                "properties": {
                  "amount": { "type": "number", "minimum": 0.01 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Budget updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "budget": { "$ref": "#/components/schemas/Budget" }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      },
      "delete": {
        "tags": ["Budgets"],
        "summary": "Delete a budget",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "budget", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Budget deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Budget deleted." }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/contexts": {
      "get": {
        "tags": ["Contexts"],
        "summary": "List user's contexts (personal + groups)",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "List of contexts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Context" }
                }
              }
            }
          }
        }
      }
    },
    "/contexts/groups": {
      "post": {
        "tags": ["Contexts"],
        "summary": "Create a new group context",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "maxLength": 100, "example": "House Expenses" },
                  "description": { "type": "string", "maxLength": 500 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Group created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "context": { "$ref": "#/components/schemas/Context" },
                    "invite_code": { "type": "string" },
                    "invite_link": { "type": "string" }
                  }
                }
              }
            }
          },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/contexts/join": {
      "post": {
        "tags": ["Contexts"],
        "summary": "Join a group via invite code",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["invite_code"],
                "properties": {
                  "invite_code": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Join request sent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Join request sent. Waiting for admin approval." },
                    "context": { "$ref": "#/components/schemas/Context" }
                  }
                }
              }
            }
          },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/contexts/{context}": {
      "get": {
        "tags": ["Contexts"],
        "summary": "Get context details with members",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "context", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Context details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Context" }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/contexts/{context}/approve/{userId}": {
      "post": {
        "tags": ["Contexts"],
        "summary": "Approve a pending member (admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "context", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Member approved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Member approved." },
                    "member": { "$ref": "#/components/schemas/ContextMember" }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/contexts/{context}/members/{userId}": {
      "delete": {
        "tags": ["Contexts"],
        "summary": "Remove a member (admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "context", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Member removed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Member removed successfully." }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/contexts/{context}/transfer-admin": {
      "post": {
        "tags": ["Contexts"],
        "summary": "Transfer admin rights to another member",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "context", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["user_id"],
                "properties": {
                  "user_id": { "type": "string", "format": "uuid" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Admin rights transferred",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Admin rights transferred successfully." }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/contexts/{context}/revoke-invite": {
      "post": {
        "tags": ["Contexts"],
        "summary": "Revoke current invite code and generate new one",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "context", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Invite code revoked",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string" },
                    "invite_code": { "type": "string" },
                    "invite_link": { "type": "string" }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/dashboard": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Dashboard overview (total spent, balance, member count)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "context_id", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Dashboard overview",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total_spent": { "type": "number" },
                    "your_balance": { "type": "number" },
                    "member_count": { "type": "integer" }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/dashboard/chart": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Daily expense totals (last 30 days)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "context_id", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Daily totals array",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "date": { "type": "string", "format": "date" },
                      "total": { "type": "number" }
                    }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/dashboard/activity": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Recent expenses activity (last 10)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "context_id", "in": "query", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Recent activity feed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Expense" }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Enter JWT token (Bearer <token>)"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "avatar_url": { "type": "string", "nullable": true },
          "is_premium": { "type": "boolean" },
          "plan_id": { "type": "string", "format": "uuid", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "context_id": { "type": "string", "format": "uuid", "nullable": true },
          "name": { "type": "string" },
          "icon": { "type": "string" },
          "is_system": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Expense": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "context_id": { "type": "string", "format": "uuid" },
          "category_id": { "type": "string", "format": "uuid", "nullable": true },
          "created_by": { "type": "string", "format": "uuid" },
          "amount": { "type": "number" },
          "expense_date": { "type": "string", "format": "date" },
          "note": { "type": "string", "nullable": true },
          "split_type": { "type": "string", "enum": ["none", "equal", "custom", "percentage"] },
          "is_settled": { "type": "boolean" },
          "category": { "$ref": "#/components/schemas/Category" },
          "creator": { "$ref": "#/components/schemas/User" },
          "splits": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ExpenseSplit" }
          },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ExpenseSplit": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "expense_id": { "type": "string", "format": "uuid" },
          "user_id": { "type": "string", "format": "uuid" },
          "share_amount": { "type": "number", "nullable": true },
          "percentage": { "type": "number", "nullable": true },
          "user": { "$ref": "#/components/schemas/User" }
        }
      },
      "Budget": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "context_id": { "type": "string", "format": "uuid" },
          "category_id": { "type": "string", "format": "uuid", "nullable": true },
          "month": { "type": "integer" },
          "year": { "type": "integer" },
          "amount": { "type": "number" },
          "spent": { "type": "number", "description": "Amount spent so far (calculated)" },
          "percentage": { "type": "number", "description": "Percentage consumed (calculated)" },
          "category": { "$ref": "#/components/schemas/Category" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "Context": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "owner_id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["personal", "group"] },
          "description": { "type": "string", "nullable": true },
          "invite_code": { "type": "string", "nullable": true },
          "members": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ContextMember" }
          },
          "pendingMembers": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ContextMember" }
          },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "ContextMember": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "context_id": { "type": "string", "format": "uuid" },
          "user_id": { "type": "string", "format": "uuid" },
          "role": { "type": "string", "enum": ["admin", "member"] },
          "status": { "type": "string", "enum": ["active", "pending", "removed"] },
          "user": { "$ref": "#/components/schemas/User" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Settlement": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "context_id": { "type": "string", "format": "uuid" },
          "payer_id": { "type": "string", "format": "uuid" },
          "receiver_id": { "type": "string", "format": "uuid" },
          "amount": { "type": "number" },
          "method": { "type": "string", "nullable": true },
          "note": { "type": "string", "nullable": true },
          "payer": { "$ref": "#/components/schemas/User" },
          "receiver": { "$ref": "#/components/schemas/User" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": { "type": "string", "example": "Invalid credentials." }
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "Forbidden",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": { "type": "string" }
              }
            }
          }
        }
      },
      "ValidationError": {
        "description": "Validation error",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": { "type": "string" },
                "errors": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
